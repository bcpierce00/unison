(rule
 (enabled_if
  (= %{env:GETTEXT_ENABLED=0} "1"))
 (target gettext_lib_enabled.ml)
 (action (with-stdout-to %{target} (echo ""))))
(rule
 (enabled_if
  (= %{env:GETTEXT_ENABLED=0} "1"))
 (target langs_lib.disabled.ml)
 (action (with-stdout-to %{target} (echo ""))))

(rule
  (enabled_if
   (= %{env:GETTEXT_ENABLED=0} "1"))
 ;(deps languages/langs_lib.enabled.ml languages/langs_lib.disabled.ml)
   (target msgs.ml)
 ;   (target langs_lib.enabled.ml)
  (action (copy languages/langs_lib.enabled.ml %{target})))

(rule
 (enabled_if
  (= %{env:GETTEXT_ENABLED=0} "1"))
 (target link_check.enabled.ml)
 (action (with-stdout-to %{target} (echo ""))))
(rule
 (enabled_if
  (= %{env:GETTEXT_ENABLED=0} "1"))
 (target link_check.disabled.ml)
 (action (with-stdout-to %{target} (echo ""))))

;;;;;;;;;;;;;;;;;;;;

 (rule
  (enabled_if
   (<> %{env:GETTEXT_ENABLED=0} "1"))
 ;(deps languages/langs_lib.enabled.ml languages/langs_lib.disabled.ml)
  (target msgs.ml)
 ;  (target langs_lib.disabled.ml)
  (action (copy languages/langs_lib.disabled.ml %{target})))

(rule
 (enabled_if
  (<> %{env:GETTEXT_ENABLED=0} "1"))
 (target langs_lib.disabled.ml)
 (action (with-stdout-to %{target} (echo ""))))

(rule
 (enabled_if
  (<> %{env:GETTEXT_ENABLED=0} "1"))
  (target link_check.disabled.ml)
 (action (with-stdout-to %{target} (echo ""))))

