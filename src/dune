(library
 (name unison_lib)
 (wrapped false)
 (modules :standard \ linktext linkgtk3 uigtk3 pixmaps uimacbridge test make_tools compat_digest)
 (modules_without_implementation ui)
 (flags :standard
        -open Compat_digest
        -w -3-6-9-10-26-27-32-34-35-38-39-50-52
        -warn-error -3-6-9-10-26-27-32-34-35-39-50-52
        -no-strict-sequence)
 (foreign_stubs
  (language c)
  (names bytearray_stubs osxsupport pty hash_compat props_xattr props_acl copy_stubs))
 (c_library_flags -lutil)
 (libraries compat str unix lwt_lib bigarray
  (select langs_lib.ml from
    ;(conditional_translation -> msgs.ml)
    ;(!conditional_translation -> msgs.ml))
    (conditional_translation -> langs_lib.enabled.ml)
    ;(!conditional_translation -> langs_lib.disabled.ml))
    (-> langs_lib.disabled.ml))
  (select link_check.ml from
    (conditional_translation -> link_check.enabled.ml)
    ;(!internationalization -> link_check.disabled.ml)
    (-> link_check.disabled.ml)
  )
 )
)

